# ==========================================
# 🔐 KREDENSIAL BINANCE API
# ==========================================
# Gunakan API Key Binance Futures Testnet untuk uji coba
BINANCE_API_KEY=masukkan_api_key_anda_di_sini
BINANCE_SECRET_KEY=masukkan_secret_key_anda_di_sini

# ==========================================
# ⚙️ PENGATURAN LINGKUNGAN (MODE)
# ==========================================
# Pilih: TESTNET atau MAINNET
MODE=TESTNET

# ==========================================
# 💰 PENGATURAN TRADING & MANAJEMEN RISIKO
# ==========================================
# USDT yang digunakan sebagai margin awal per posisi
MARGIN_USDT=1.0

# Leverage (Bot akan mengatur otomatis di akun Anda)
LEVERAGE=10

# Minimal Risk/Reward (RR) ratio
MIN_RR=1.5

# Batas maksimal bot boleh trading per hari
MAX_TRADES_PER_DAY=5

# ==========================================
# 📱 NOTIFIKASI TELEGRAM
# ==========================================
TELEGRAM_TOKEN=masukkan_token_bot_telegram_anda
TELEGRAM_CHAT_ID=masukkan_chat_id_anda