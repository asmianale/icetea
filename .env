# ==========================================
# KREDENSIAL BINANCE (Bisa diedit via Telegram)
# ==========================================
BINANCE_API_KEY=masukkan_api_key_binance_abang_disini
BINANCE_SECRET_KEY=masukkan_secret_key_binance_abang_disini

# ==========================================
# KREDENSIAL TELEGRAM (Wajib diisi manual)
# ==========================================
TELEGRAM_TOKEN=masukkan_token_bot_telegram_disini
TELEGRAM_CHAT_ID=masukkan_chat_id_telegram_abang_disini

# ==========================================
# PENGATURAN TRADING (Bisa diedit via Telegram)
# ==========================================
# Gunakan LIVE atau MAINNET untuk uang asli, TESTNET untuk demo
MODE=TESTNET 

# Modal margin USDT per posisi (Misal: 1.0)
MARGIN_USDT=1.0 

# Nilai Leverage (Misal: 10 atau 20)
LEVERAGE=20 

# Minimal Risk/Reward (RR) agar bot mau ambil posisi
MIN_RR=1.5 

# Jarak napas Stop Loss (%) dari ujung ekor candle agar tidak mudah tersapu jarum
# 0.15 - 0.20 adalah angka ideal.
SL_BUFFER_PCT=0.15
